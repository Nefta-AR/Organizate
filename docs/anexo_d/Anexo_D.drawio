  <diagram name="D4 - Despliegue" id="d4-despliegue">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="d4-0" />
        <mxCell id="d4-1" parent="d4-0" />

        <mxCell id="d4-t" value="&lt;b&gt;D.4 Diagrama de Despliegue - Infraestructura Firebase&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontColor=#2E7D32;" vertex="1" parent="d4-1">
          <mxGeometry x="40" y="20" width="550" height="30" as="geometry" />
        </mxCell>

        <!-- CLIENTE -->
        <mxCell id="d4-client-box" value="&lt;b&gt;📱 Dispositivo Móvil&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontColor=#1565C0;startSize=30;" vertex="1" parent="d4-1">
          <mxGeometry x="40" y="80" width="320" height="280" as="geometry" />
        </mxCell>
        <mxCell id="d4-flutter" value="&lt;b&gt;Flutter App&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;10&quot;&gt;Android / iOS&lt;br&gt;&lt;br&gt;• Auth SDK&lt;br&gt;• Firestore SDK&lt;br&gt;• Storage SDK&lt;br&gt;• Cloud Functions (HTTPS Callable)&lt;br&gt;&lt;br&gt;Capa UI (Screens, Widgets)&lt;br&gt;Servicios (Auth, Pictogram, Notification)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565C0;strokeWidth=1.5;" vertex="1" parent="d4-client-box">
          <mxGeometry x="20" y="45" width="280" height="220" as="geometry" />
        </mxCell>

        <!-- FIREBASE BACKEND -->
        <mxCell id="d4-fb-box" value="&lt;b&gt;☁️ Backend Firebase&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontColor=#2E7D32;startSize=30;" vertex="1" parent="d4-1">
          <mxGeometry x="400" y="80" width="620" height="520" as="geometry" />
        </mxCell>

        <mxCell id="d4-auth" value="&lt;b&gt;🔐 Firebase Authentication&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;9&quot;&gt;Email/Password | Google Sign-In (OAuth 2.0)&lt;br&gt;Custom Claims: role=tutor|usuario&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;strokeWidth=1.5;" vertex="1" parent="d4-fb-box">
          <mxGeometry x="20" y="45" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="d4-firestore" value="&lt;b&gt;🗄️ Cloud Firestore&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;9&quot;&gt;Native mode | Region: us-central1&lt;br&gt;Colecciones: users, invitationCodes, notificationQueue&lt;br&gt;Subcolecciones: tasks, pictograms, activityLog, linkedTutors&lt;br&gt;Índices compuestos | Reglas RBAC&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;strokeWidth=1.5;" vertex="1" parent="d4-fb-box">
          <mxGeometry x="20" y="130" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d4-storage" value="&lt;b&gt;📦 Firebase Storage&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;9&quot;&gt;Bucket: organizate-26065.appspot.com&lt;br&gt;Path: users/{uid}/pictograms/{file}.jpg&lt;br&gt;Rules: owner or linkedTutor&lt;br&gt;Metadata: uploadedBy, createdAt&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;strokeWidth=1.5;" vertex="1" parent="d4-fb-box">
          <mxGeometry x="20" y="235" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d4-functions" value="&lt;b&gt;⚡ Cloud Functions (Node.js 18)&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;9&quot;&gt;• desglosarTarea → Gemini AI (256MB, 10s)&lt;br&gt;• sintetizarVoz → Google TTS (Neural2)&lt;br&gt;• processDueNotifications → FCM (cron 1min)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;strokeWidth=1.5;" vertex="1" parent="d4-fb-box">
          <mxGeometry x="320" y="45" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d4-fcm" value="&lt;b&gt;📲 Firebase Cloud Messaging&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;9&quot;&gt;notificationQueue → Cloud Fn → FCM → Device&lt;br&gt;Mensajes directos por token (no topics)&lt;br&gt;Payload: taskTitle, dueDate, reminderMinutes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;strokeWidth=1.5;" vertex="1" parent="d4-fb-box">
